ITAD_API_KEY=your_api_key_here

# IGDB (via Twitch Developer credentials) — optional, enables rating sort
# Register at https://dev.twitch.tv/console and create an application
IGDB_CLIENT_ID=your_twitch_client_id
IGDB_CLIENT_SECRET=your_twitch_client_secret

# Redis connection URL (required for caching)
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# PostgreSQL connection URL (required for persistent data: title mappings, controller support, IGDB data)
# Matches the docker-compose.yml defaults — change for production
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/steamuready

# Set to true to skip the Steam controller support warm-up on startup.
# Useful locally when running the seed generation script to avoid racing Steam's rate limit.
# SKIP_CTRL_WARM=true
