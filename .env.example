ITAD_API_KEY=your_api_key_here

# IGDB (via Twitch Developer credentials) — optional, enables rating sort
# Register at https://dev.twitch.tv/console and create an application
IGDB_CLIENT_ID=your_twitch_client_id
IGDB_CLIENT_SECRET=your_twitch_client_secret

# Redis connection URL (required for caching)
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379
